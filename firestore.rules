rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 편지 컬렉션
    match /letters/{letterId} {

      // 누구나 케이크의 편지를 읽을 수 있음 (열람 시 비번 확인은 클라이언트에서)
      allow read: if true;

      // 누구나 편지를 남길 수 있음 (로그인 없음). 단, 필수 필드/타입을 검증.
      allow create: if request.resource.data.keys().hasAll(
                        ['name', 'passwordHash', 'content', 'decoration', 'slot', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.passwordHash is string
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 500;

      // 수정은 내용/장식/음악만 가능 (작성자/비번/슬롯은 변경 불가).
      // 비번 검증은 클라이언트에서 수행.
      allow update: if request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['content', 'decoration', 'music']);

      // 삭제는 콘솔에서만 (앱에서 불가).
      allow delete: if false;
    }
  }
}
